#!/usr/bin/make -f
# Debian rules for peek / peekd

export DH_VERBOSE = 1
export CARGO_HOME = $(CURDIR)/debian/cargo-home
export RUST_BACKTRACE = 1

%:
	dh $@

override_dh_auto_build:
	cargo build --release --workspace

override_dh_auto_test:
	cargo test --workspace

override_dh_auto_install:
	# peek binary
	install -Dm755 target/release/peek \
		debian/peek/usr/bin/peek

	# peekd binary
	install -Dm755 target/release/peekd \
		debian/peekd/usr/bin/peekd

	# systemd unit
	install -Dm644 packaging/peekd.service \
		debian/peekd/lib/systemd/system/peekd.service

	# Man page for peek (section 1), generated by peek-cli build.rs
	MAN=$$(find target -name 'peek.1' 2>/dev/null | head -1); \
	if [ -n "$$MAN" ]; then \
		install -Dm644 "$$MAN" debian/peek/usr/share/man/man1/peek.1; \
	fi

	# Man page for peekd (section 8), generated by peekd build.rs
	MAN8=$$(find target -name 'peekd.8' 2>/dev/null | head -1); \
	if [ -n "$$MAN8" ]; then \
		install -Dm644 "$$MAN8" debian/peekd/usr/share/man/man8/peekd.8; \
	fi

	# Shell completions
	BASH=$$(find target -name 'peek.bash' 2>/dev/null | head -1); \
	[ -n "$$BASH" ] && install -Dm644 "$$BASH" \
		debian/peek/usr/share/bash-completion/completions/peek || true

	ZSH=$$(find target -name '_peek' 2>/dev/null | head -1); \
	[ -n "$$ZSH" ] && install -Dm644 "$$ZSH" \
		debian/peek/usr/share/zsh/vendor-completions/_peek || true

	FISH=$$(find target -name 'peek.fish' 2>/dev/null | head -1); \
	[ -n "$$FISH" ] && install -Dm644 "$$FISH" \
		debian/peek/usr/share/fish/vendor_completions.d/peek.fish || true

override_dh_auto_clean:
	cargo clean
	rm -rf debian/cargo-home


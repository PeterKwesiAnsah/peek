# Maintainer: peek contributors <peek@example.com>
pkgbase=peek
pkgname=('peek' 'peekd')
pkgver=0.1.0
pkgrel=1
pkgdesc="The Process Intelligence Tool for Linux"
arch=('x86_64' 'aarch64')
url="https://github.com/ankittk/peek"
license=('MIT')
makedepends=('rust' 'cargo')
source=("$pkgbase-$pkgver.tar.gz::https://github.com/ankittk/peek/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgbase-$pkgver"
    cargo build --release --workspace
}

check() {
    cd "$pkgbase-$pkgver"
    cargo test --workspace
}

package_peek() {
    pkgdesc="peek CLI — process intelligence tool for Linux"
    depends=('glibc')
    cd "$pkgbase-$pkgver"

    install -Dm755 target/release/peek "$pkgdir/usr/bin/peek"

    # Man page (generated by build.rs)
    _man=$(find target -name 'peek.1' 2>/dev/null | head -1)
    [[ -n "$_man" ]] && install -Dm644 "$_man" "$pkgdir/usr/share/man/man1/peek.1"

    # Shell completions
    _bash=$(find target -name 'peek.bash' 2>/dev/null | head -1)
    _zsh=$(find target -name '_peek' 2>/dev/null | head -1)
    _fish=$(find target -name 'peek.fish' 2>/dev/null | head -1)
    [[ -n "$_bash" ]] && install -Dm644 "$_bash" "$pkgdir/usr/share/bash-completion/completions/peek"
    [[ -n "$_zsh"  ]] && install -Dm644 "$_zsh"  "$pkgdir/usr/share/zsh/site-functions/_peek"
    [[ -n "$_fish" ]] && install -Dm644 "$_fish" "$pkgdir/usr/share/fish/vendor_completions.d/peek.fish"

    install -Dm644 README.md  "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_peekd() {
    pkgdesc="peekd — background daemon for peek resource history and alerting"
    depends=('peek')
    cd "$pkgbase-$pkgver"

    install -Dm755 target/release/peekd     "$pkgdir/usr/bin/peekd"
    install -Dm644 packaging/peekd.service  "$pkgdir/usr/lib/systemd/system/peekd.service"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

